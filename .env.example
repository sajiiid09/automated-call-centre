# Copy to .env and fill in. Never commit .env.

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://acc:acc@localhost:5433/callcentre

# Twilio (Phase 3+)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # E.164, e.g. +44xxxxxxxxxx

# AI providers (Phase 3+)
DEEPGRAM_API_KEY=
GEMINI_API_KEY=

# Public HTTPS base URL for Twilio webhooks (ngrok, Phase 3+)
PUBLIC_BASE_URL=
